{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GMind",
  "version": "0.1.0",
  "identifier": "com.gmind.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "GMind",
        "width": 760,
        "height": 640,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Personal knowledge tray app",
    "longDescription": "GMind is a personal knowledge tray app backed by PostgreSQL and pgvector."
  }
}
